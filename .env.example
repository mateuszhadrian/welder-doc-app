# =============================================================================
# WelderDoc — szablon zmiennych środowiskowych (tech-stack §13)
# Skopiuj do .env.local i uzupełnij; .env.local jest w .gitignore.
# =============================================================================

# ----- Supabase (lokalnie wartości z `supabase start`) -----
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Tylko server-side; używane w app/api/paddle/webhook/route.ts (upsert)
# oraz app/api/cron/{expire-subscriptions,cleanup-webhook-events}/route.ts (brak JWT).
# /api/consent NIE używa tego klucza — RPC record_consent_bundle to SECURITY
# DEFINER (wykonuje się jako rola postgres), handler operuje na kliencie sesji.
SUPABASE_SERVICE_ROLE_KEY=

# Project ID dla skryptu pnpm supabase:types (zdalna instancja, post-bootstrap)
SUPABASE_PROJECT_ID=

# ----- Paddle (post-bootstrap; zostawić puste do momentu założenia konta) -----
NEXT_PUBLIC_PADDLE_CLIENT_TOKEN=
NEXT_PUBLIC_PADDLE_ENV=sandbox
PADDLE_WEBHOOK_SECRET=
# Price IDs z Paddle Dashboard → Catalog → Prices
NEXT_PUBLIC_PADDLE_PRICE_ID_PRO_MONTHLY=
NEXT_PUBLIC_PADDLE_PRICE_ID_PRO_ANNUAL=

# ----- App -----
NEXT_PUBLIC_APP_URL=http://localhost:3000
# Losowy sekret do weryfikacji wywołań Vercel Cron (/api/cron/*)
# Generuj np.: openssl rand -base64 32
CRON_SECRET=

# =============================================================================
# CI / staging (analiza §4.6) — używane wyłącznie w GitHub Actions po podpięciu
# Sekrety dodawane przez GitHub UI, nie commitujemy ich.
# =============================================================================
# STAGING_SUPABASE_URL=
# STAGING_SUPABASE_ANON_KEY=
